--- !u!114 &1804358446
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1804358444}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: beaa34cb0e58d624bb3a264b28600785, type: 3}
  m_Name: 
  m_EditorClassIdentifier: LSCore.UIModule::UniText
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 1, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  text: "\u0623\u0646\u0627 \u0645\u0648\u0627\u0641\u0642 \u062A\u0645\u0627\u0645\u0627\u064B!
    \U0001F44D The match was legendary \u2014 \u0644\u0645 \u0623\u0631\u064E \u0645\u062B\u0644
    \u0647\u0630\u0627 \u0627\u0644\u0623\u062F\u0627\u0621 \u0645\u0646\u0630 \u0633\u0646\u0648\u0627\u062A!
    \u062E\u0627\u0635\u0629 \u0627\u0644\u0647\u062F\u0641 \u0627\u0644\u062B\u0627\u0644\u062B\u060C
    it was pure magic! \u0646\u0639\u0645\u060C \u0623\u0646\u0627 \u0645\u062A\u0641\u0631\u063A
    \u064A\u0648\u0645 \u0627\u0644\u0633\u0628\u062A. Let's meet at the usual place
    around 7 PM? \u064A\u0645\u0643\u0646\u0646\u0627 \u0645\u0634\u0627\u0647\u062F\u0629
    \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0642\u0627\u062F\u0645\u0629
    \u0645\u0639\u0627\u064B \u0648\u0646\u0637\u0644\u0628 \u0628\u064A\u062A\u0632\u0627
    \U0001F355 \u2014 what do you think? \u0623\u062E\u0628\u0631\u0646\u064A \u0625\u0630\u0627
    \u0643\u0627\u0646 \u0627\u0644\u0645\u0648\u0639\u062F \u0645\u0646\u0627\u0633\u0628\u0627\u064B
    \u0644\u0643!\n"
  fontStack: {fileID: 11400000, guid: 72f6e3edfbc82804791ebe8e4814fa46, type: 2}
  appearance: {fileID: 11400000, guid: 36ee3940d360ced43a59dd530844bf3d, type: 2}
  fontSize: 32
  baseDirection: 2
  wordWrap: 1
  horizontalAlignment: 0
