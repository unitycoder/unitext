  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  text: "Hey there! I'm doing great, thanks for asking! \U0001F389 Yes, I watched
    the game yesterday and it was absolutely incredible! The team played so well,
    especially in the second half. Those three goals were amazing \u2014 did you
    see that last one? The goalkeeper had no chance! By the way, are you free this
    weekend? We should hang out and watch the next match together. Let me know what
    you think!\n"
  fontStack: {fileID: 11400000, guid: 72f6e3edfbc82804791ebe8e4814fa46, type: 2}
  appearance: {fileID: 11400000, guid: 36ee3940d360ced43a59dd530844bf3d, type: 2}
  fontSize: 32
  baseDirection: 2
  wordWrap: 1
  horizontalAlignment: 0
  verticalAlignment: 0
  autoSize: 0
  minFontSize: 10
  maxFontSize: 72
  modRegisters:
    items: []
  modRegisterConfigs:
    items: []
  highlighter:
    rid: 266425111468834867
  references:
    version: 2
    RefIds:
    - rid: 266425111468834867
      type: {class: DefaultTextHighlighter, ns: LightSide, asm: LightSide.UniText}
