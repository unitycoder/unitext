  text: "\u0645\u0631\u062D\u0628\u0627\u064B \u064A\u0627 \u0635\u062F\u064A\u0642\u064A!
    \u0643\u064A\u0641 \u062D\u0627\u0644\u0643 \u0627\u0644\u064A\u0648\u0645\u061F
    \U0001F60A \u0623\u062A\u0645\u0646\u0649 \u0623\u0646 \u064A\u0643\u0648\u0646
    \u064A\u0648\u0645\u0643 \u0631\u0627\u0626\u0639\u0627\u064B. \u0647\u0644 \u0634\u0627\u0647\u062F\u062A
    \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0623\u0645\u0633\u061F \u0643\u0627\u0646\u062A
    \u0645\u062B\u064A\u0631\u0629 \u062C\u062F\u0627\u064B! \u0627\u0644\u0641\u0631\u064A\u0642
    \u0644\u0639\u0628 \u0628\u0634\u0643\u0644 \u0645\u0645\u062A\u0627\u0632 \u0648\u0633\u062C\u0651\u0644
    \u062B\u0644\u0627\u062B\u0629 \u0623\u0647\u062F\u0627\u0641 \u0641\u064A \u0627\u0644\u0634\u0648\u0637
    \u0627\u0644\u062B\u0627\u0646\u064A. \u0623\u0646\u0627 \u0633\u0639\u064A\u062F
    \u062C\u062F\u0627\u064B \u0628\u0627\u0644\u0646\u062A\u064A\u062C\u0629. \u0645\u0627
    \u0631\u0623\u064A\u0643 \u0641\u064A \u0623\u062F\u0627\u0621 \u0627\u0644\u0644\u0627\u0639\u0628\u064A\u0646\u061F"
  fontStack: {fileID: 11400000, guid: 72f6e3edfbc82804791ebe8e4814fa46, type: 2}
  appearance: {fileID: 11400000, guid: 36ee3940d360ced43a59dd530844bf3d, type: 2}
